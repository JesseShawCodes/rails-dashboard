<section class="hero is-primary is-fullheight">
  <div class="hero-body">
    <div class="container has-text-centered">
      <h1 class="title is-1">
        Music Analytics
      </h1>
      <h2 class="subtitle is-3">
        Your music, your stats.
      </h2>
      <p>Discover insights into your listening habits.</p>
      <div class="mt-5">
        <% if user_signed_in? %>
          <%= link_to "Go to Dashboard", authenticated_root_path, class: "button is-primary is-inverted is-outlined" %>
        <% else %>
          <div class="buttons is-centered">
            <%= link_to "Sign Up", new_user_registration_path, class: "button is-primary is-inverted is-outlined" %>
            <%= link_to "Log In", new_user_session_path, class: "button is-primary is-inverted is-outlined" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
